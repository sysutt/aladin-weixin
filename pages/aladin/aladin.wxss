/* pages/aladin/aladin.wxss */
/* 注意：cover-view 不支持 animation / overflow / pointer-events / white-space 等部分 CSS */

page { background: #000510; }

/* ── 根容器 ─────────────────────────────────────────────────── */
.root {
  position: relative;
  background: #000510;
}

/* ── 画布：绝对定位铺满 ─────────────────────────────────────── */
.starmap {
  display: block;
  position: absolute;
  top: 0; left: 0;
  z-index: 1;
}

/* ── 初始化蒙层 ─────────────────────────────────────────────── */
.mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #000510;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
}

.mask-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.mask-text {
  font-size: 30rpx;
  color: #c0d4f0;
  margin-bottom: 16rpx;
}

.mask-hint {
  font-size: 24rpx;
  color: rgba(160,190,230,.55);
  text-align: center;
}

/* ── 瓦片加载角标 ────────────────────────────────────────────── */
.tile-loading {
  position: absolute;
  top: 64rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(0,8,24,.75);
  border-radius: 24rpx;
  padding: 6rpx 18rpx;
  z-index: 20;
}

.tile-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #5eaaff;
  margin-right: 10rpx;
}

.tile-text {
  font-size: 22rpx;
  color: #8ab8e0;
}

/* ── 顶部坐标栏 ──────────────────────────────────────────────── */
.topbar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 56rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(0,5,16,.72);
  z-index: 10;
}

.coords {
  font-size: 22rpx;
  color: #a0c8e8;
}

.fov-tag {
  font-size: 22rpx;
  color: rgba(130,180,240,.7);
}

/* ── 右侧缩放按钮 ────────────────────────────────────────────── */
.zoom-btns {
  position: absolute;
  right: 20rpx;
  top: 50%;
  margin-top: -88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.zoom-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(20,40,80,.82);
  border: 1rpx solid rgba(100,160,240,.3);
  border-radius: 36rpx;
  color: #a0c8f0;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* cover-view 不支持 gap，用 margin-top 代替 */
.zm-gap {
  margin-top: 16rpx;
}

/* ── 底部控制面板 ────────────────────────────────────────────── */
.panel {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  background: rgba(4,12,30,.9);
  border-top: 1rpx solid rgba(80,140,240,.2);
  z-index: 10;
}

/* ── 快捷目标（手动滚动容器）────────────────────────────────── */
.targets-wrap {
  width: 100%;
  height: 72rpx;
  padding: 14rpx 0 0;
  overflow: hidden;
}

.targets-inner {
  display: flex;
  flex-direction: row;
  padding-left: 16rpx;
}

.target-btn {
  flex-shrink: 0;
  margin-right: 14rpx;
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #a0c0e0;
  background: rgba(40,80,160,.35);
}

.target-btn.active {
  background: rgba(60,120,255,.55);
  color: #fff;
}

/* ── 工具栏 ──────────────────────────────────────────────────── */
.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 16rpx 16rpx;
}

.tool-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
  border-radius: 12rpx;
}

.tool-btn.on {
  background: rgba(60,110,220,.3);
}

.tool-icon {
  font-size: 32rpx;
  color: #7aa8c8;
}

.tool-btn.on .tool-icon {
  color: #7acdff;
}

.tool-label {
  font-size: 20rpx;
  color: rgba(150,190,230,.7);
  margin-top: 4rpx;
}
